{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A marketing project containing notes and a generated kit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "marketType": { "type": "string", "enum": ["niche", "saturated"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "notes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "content": { "type": "string" },
              "imageUrl": { "type": "string" },
              "createdAt": { "type": "number" }
            }
          }
        },
        "kit": { "type": "object" }
      },
      "required": ["id", "name", "marketType", "ownerId", "createdAt", "updatedAt", "notes"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User marketing projects"
    }
  }
}
