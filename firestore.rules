rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - marketType: string (required, 'niche' or 'saturated')
    //   - ownerId: string (required, matches auth.uid)
    //   - createdAt: number (required)
    //   - updatedAt: number (required)
    //   - notes: list (required, max 100 items)
    //     - id: string
    //     - content: string (max 10000 chars)
    //     - imageUrl: string (optional, URL)
    //     - createdAt: number
    //   - kit: map (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'marketType', 'ownerId', 'createdAt', 'updatedAt', 'notes']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.marketType in ['niche', 'saturated'] &&
             data.ownerId == request.auth.uid &&
             data.notes is list && data.notes.size() <= 100;
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidProject(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
